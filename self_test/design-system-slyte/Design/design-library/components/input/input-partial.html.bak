                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Base</span>
                                        <div class="zc-input-wrapper zc-input-wrapper-readonly">
                                            <input class="zc-input" type="text" value="Read-only value" readonly />

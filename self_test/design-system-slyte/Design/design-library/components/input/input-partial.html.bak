                    <div class="detail-header">
                        <div class="detail-icon"><i class="fas fa-keyboard"></i></div>
                        <div class="detail-info">
                            <h1 class="detail-title">Text Input</h1>
                            <p class="detail-description">Text input field using <code>&lt;lyte-input&gt;</code> Slyte DOM. States: Empty, Filled, Focus, Hover, Disabled, Read-only, Error, Success with optional prefix/suffix icons and label support.</p>
                            <div class="detail-meta">
                                <span class="meta-tag"><i class="fas fa-folder"></i> Form</span>
                                <span class="meta-tag"><i class="fab fa-figma"></i> Figma Synced</span>
                                <span class="meta-tag"><i class="fas fa-layer-group"></i> 10 States × 1 Size</span>
                            </div>
                        </div>
                    </div>

                    <!-- Style Tabs -->
                    <div class="btn-style-tabs zc-mb-16 zc-mt-8">
                        <button class="btn-style-tab active" onclick="switchInputStyleTab('default', this)">Default</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('filled', this)">Filled</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('focus', this)">Focus</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('hover', this)">Hover</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('disabled', this)">Disabled</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('readonly', this)">Read-only</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('error', this)">Error</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('success', this)">Success</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('with-icons', this)">With Icons</button>
                        <button class="btn-style-tab" onclick="switchInputStyleTab('with-label', this)">With Label</button>
                    </div>

                    <div id="input-component-variants">

                        <!-- ==== DEFAULT (EMPTY) ==== -->
                        <div class="btn-variant-group" data-style="default">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Default — Empty Input</span><button class="btn-variant-card__toggle" onclick="toggleInputCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Base</span>
                                        <div class="zc-input-wrapper">
                                            <input class="zc-input" type="text" placeholder="Enter text..." />
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Default empty input --&gt;
&lt;div class="zc-input-wrapper"&gt;
  &lt;input class="zc-input" type="text" placeholder="Enter text..." /&gt;
&lt;/div&gt;

&lt;!-- Using Lyte component --&gt;
&lt;lyte-input class="zc-input-wrapper"&gt;
  &lt;template is="registerYield" yield-name="input"&gt;
    &lt;input class="zc-input" type="text" placeholder="Enter text..." /&gt;
  &lt;/template&gt;
&lt;/lyte-input&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper {
  display: flex;
  align-items: center;
  height: 36px;
  border: 1px solid var(--zc-color-neutral-border-neutral-border-default, #D5D6D9);
  border-radius: var(--zc-radius-r, 6px);
  background: var(--zc-color-black-white-surface-white-surface, #FFFFFF);
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
  overflow: hidden;
}
.zc-input {
  flex: 1;
  height: 100%;
  padding: 8px 12px;
  border: none;
  outline: none;
  background: transparent;
  font-family: 'ZohoPuvi', sans-serif;
  font-size: var(--zc-p2-font-size, 14px);
  color: var(--zc-color-neutral-text-neutral-text-default, #37383C);
}
.zc-input::placeholder {
  color: var(--zc-color-neutral-text-neutral-text-subtle, #9EA0A7);
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== FILLED ==== -->
                        <div class="btn-variant-group" data-style="filled" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Filled — Input with Value</span><button class="btn-variant-card__toggle" onclick="toggleInputCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Base</span>
                                        <div class="zc-input-wrapper zc-input-wrapper-filled">
                                            <input class="zc-input" type="text" value="John Doe" />
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;div class="zc-input-wrapper zc-input-wrapper-filled"&gt;
  &lt;input class="zc-input" type="text" value="John Doe" /&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper-filled .zc-input {
  color: var(--zc-color-neutral-text-neutral-text-default, #37383C);
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== FOCUS ==== -->
                        <div class="btn-variant-group" data-style="focus" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Focus — Blue Border with Shadow</span><button class="btn-variant-card__toggle" onclick="toggleInputCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Base</span>
                                        <div class="zc-input-wrapper zc-input-wrapper-focus">
                                            <input class="zc-input" type="text" placeholder="Focused input..." />
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Focus state applied automatically via :focus-within --&gt;
&lt;div class="zc-input-wrapper"&gt;
  &lt;input class="zc-input" type="text" placeholder="Focused input..." /&gt;
&lt;/div&gt;

&lt;!-- Or force with class --&gt;
&lt;div class="zc-input-wrapper zc-input-wrapper-focus"&gt;
  &lt;input class="zc-input" type="text" placeholder="Focused input..." /&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper-focus,
.zc-input-wrapper:focus-within {
  border-color: var(--zc-color-primary-border-primary-border-default, #0D4EF2);
  box-shadow: 0px 2px 2px 0px rgba(13, 78, 242, 0.05), 0px 2px 4px 0px rgba(13, 78, 242, 0.08);
}</code></pre></div>
                                </div>
                            </div>
                        </div>


                                        <div class="zc-input-field zc-input-field-error">
                                            <div class="zc-input-wrapper zc-input-wrapper-error">
                                                <input class="zc-input" type="text" value="invalid@" />
                                            </div>
                                            <span class="zc-input-hint">Please enter a valid email address</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;div class="zc-input-field zc-input-field-error"&gt;
  &lt;div class="zc-input-wrapper zc-input-wrapper-error"&gt;
    &lt;input class="zc-input" type="text" placeholder="Required field" /&gt;
  &lt;/div&gt;
  &lt;span class="zc-input-hint"&gt;This field is required&lt;/span&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper-error {
  border-color: var(--zc-color-error-border-error-border-default, #CC1914);
  background: var(--zc-color-error-surface-error-surface-subtle, #FEF6F6);
}
.zc-input-field-error .zc-input-hint {
  color: var(--zc-color-error-text-error-text-default, #CC1914);
}</code></pre></div>

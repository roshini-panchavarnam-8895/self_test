                                        <span class="btn-size-label">Default</span>
                                        <div class="zc-input-field">
                                            <label class="zc-input-label">Full Name</label>
                                            <div class="zc-input-wrapper">
                                                <input class="zc-input" type="text" placeholder="Enter your full name" />
                                            </div>
                                            <span class="zc-input-hint">First and last name</span>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">With Error</span>
                                        <div class="zc-input-field zc-input-field-error">
                                            <label class="zc-input-label">Email Address</label>
                                            <div class="zc-input-wrapper zc-input-wrapper-error">
                                                <input class="zc-input" type="text" value="invalid@" />
                                            </div>
                                            <span class="zc-input-hint">Please enter a valid email address</span>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Disabled</span>
                                        <div class="zc-input-field">
                                            <label class="zc-input-label">Username</label>
                                            <div class="zc-input-wrapper zc-input-wrapper-disabled">
                                                <input class="zc-input" type="text" value="johndoe" disabled />
                                            </div>
                                            <span class="zc-input-hint">Cannot be changed</span>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">With Prefix Icon</span>
                                        <div class="zc-input-field">
                                            <label class="zc-input-label">Search</label>
                                            <div class="zc-input-wrapper">
                                                <span class="zc-input-icon zc-input-icon-prefix"><i class="fas fa-search"></i></span>
                                                <input class="zc-input" type="text" placeholder="Search records..." />
                                            </div>
                                            <span class="zc-input-hint">Search by name or ID</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Full input field with label and hint --&gt;
&lt;div class="zc-input-field"&gt;
  &lt;label class="zc-input-label"&gt;Label&lt;/label&gt;
  &lt;div class="zc-input-wrapper"&gt;
    &lt;input class="zc-input" type="text" placeholder="Placeholder" /&gt;
  &lt;/div&gt;
  &lt;span class="zc-input-hint"&gt;Helper text&lt;/span&gt;
&lt;/div&gt;

&lt;!-- With error state --&gt;
&lt;div class="zc-input-field zc-input-field-error"&gt;
  &lt;label class="zc-input-label"&gt;Email Address&lt;/label&gt;
  &lt;div class="zc-input-wrapper zc-input-wrapper-error"&gt;
    &lt;input class="zc-input" type="text" value="invalid@" /&gt;
  &lt;/div&gt;
  &lt;span class="zc-input-hint"&gt;Please enter a valid email address&lt;/span&gt;
&lt;/div&gt;

&lt;!-- With prefix icon --&gt;
&lt;div class="zc-input-field"&gt;
  &lt;label class="zc-input-label"&gt;Search&lt;/label&gt;
  &lt;div class="zc-input-wrapper"&gt;
    &lt;span class="zc-input-icon zc-input-icon-prefix"&gt;&lt;i class="fas fa-search"&gt;&lt;/i&gt;&lt;/span&gt;
    &lt;input class="zc-input" type="text" placeholder="Search records..." /&gt;
  &lt;/div&gt;
  &lt;span class="zc-input-hint"&gt;Search by name or ID&lt;/span&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-field {
  display: flex;
  flex-direction: column;
  font-family: 'ZohoPuvi', sans-serif;
  min-width: 200px;
}
.zc-input-label {
  font-size: var(--zc-p2-font-size, 14px);
  font-weight: var(--zc-p2-font-weight-semibold, 600);
  color: var(--zc-color-neutral-text-neutral-text-default, #37383C);
  margin-bottom: 6px;
}
.zc-input-hint {
  font-size: var(--zc-p3-font-size, 12px);
  color: var(--zc-color-neutral-text-neutral-text-subtle, #9EA0A7);
  margin-top: 4px;
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                    </div>
                        <div class="btn-variant-group" data-style="hover" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Hover — Primary Border</span><button class="btn-variant-card__toggle" onclick="toggleInputCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Base</span>
                                        <div class="zc-input-wrapper" style="border-color: #0D4EF2;">
                                            <input class="zc-input" type="text" placeholder="Hover over me..." />
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Hover state applied automatically via :hover --&gt;
&lt;div class="zc-input-wrapper"&gt;
  &lt;input class="zc-input" type="text" placeholder="Hover over me..." /&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper:hover {
  border-color: var(--zc-color-primary-border-primary-border-default, #0D4EF2);
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== DISABLED ==== -->
                        <div class="btn-variant-group" data-style="disabled" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Disabled — Non-interactive</span><button class="btn-variant-card__toggle" onclick="toggleInputCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Empty</span>
                                        <div class="zc-input-wrapper zc-input-wrapper-disabled">
                                            <input class="zc-input" type="text" placeholder="Disabled input" disabled />
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">With Value</span>
                                        <div class="zc-input-wrapper zc-input-wrapper-disabled">
                                            <input class="zc-input" type="text" value="Cannot edit" disabled />
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchInputCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchInputCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;div class="zc-input-wrapper zc-input-wrapper-disabled"&gt;
  &lt;input class="zc-input" type="text" placeholder="Disabled input" disabled /&gt;
&lt;/div&gt;

&lt;div class="zc-input-wrapper zc-input-wrapper-disabled"&gt;
  &lt;input class="zc-input" type="text" value="Cannot edit" disabled /&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper-disabled {
  background: var(--zc-color-neutral-surface-neutral-surface-disabled, #F5F5F5);
  border-color: var(--zc-color-neutral-border-neutral-border-default, #D5D6D9);
  cursor: not-allowed;
}
.zc-input-wrapper-disabled .zc-input {
  cursor: not-allowed;
  color: #9EA0A7;
}</code></pre></div>
                                </div>
                            </div>
                        </div>


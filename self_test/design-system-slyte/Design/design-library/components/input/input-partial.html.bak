                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Prefix icon (search) --&gt;
&lt;div class="zc-input-wrapper"&gt;
  &lt;span class="zc-input-icon zc-input-icon-prefix"&gt;&lt;i class="fas fa-search"&gt;&lt;/i&gt;&lt;/span&gt;
  &lt;input class="zc-input" type="text" placeholder="Search..." /&gt;
&lt;/div&gt;

&lt;!-- Suffix icon (clear) --&gt;
&lt;div class="zc-input-wrapper"&gt;
  &lt;input class="zc-input" type="text" value="Some text" /&gt;
  &lt;span class="zc-input-icon zc-input-icon-suffix"&gt;&lt;i class="fas fa-times"&gt;&lt;/i&gt;&lt;/span&gt;
&lt;/div&gt;

&lt;!-- Both prefix &amp; suffix icons --&gt;
&lt;div class="zc-input-wrapper"&gt;
  &lt;span class="zc-input-icon zc-input-icon-prefix"&gt;&lt;i class="fas fa-search"&gt;&lt;/i&gt;&lt;/span&gt;
  &lt;input class="zc-input" type="text" placeholder="Search..." /&gt;
  &lt;span class="zc-input-icon zc-input-icon-suffix"&gt;&lt;i class="fas fa-times"&gt;&lt;/i&gt;&lt;/span&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  color: var(--zc-color-neutral-text-neutral-text-secondary, #696C74);
  flex-shrink: 0;
  font-size: 14px;
}
.zc-input-icon-prefix { padding-left: 4px; }
.zc-input-icon-suffix { padding-right: 4px; cursor: pointer; }</code></pre></div>

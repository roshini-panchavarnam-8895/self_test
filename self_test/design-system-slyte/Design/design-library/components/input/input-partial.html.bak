                        <div class="btn-variant-group" data-style="error" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Error — Validation Failed</span><button class="btn-variant-card__toggle" onclick="toggleInputCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">

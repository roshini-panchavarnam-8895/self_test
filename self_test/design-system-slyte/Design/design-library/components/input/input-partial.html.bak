                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;div class="zc-input-wrapper zc-input-wrapper-readonly"&gt;
  &lt;input class="zc-input" type="text" value="Read-only value" readonly /&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyInputCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-input-wrapper-readonly {
  background: #FAFAFA;
}
.zc-input-wrapper-readonly .zc-input {
  cursor: default;
}</code></pre></div>

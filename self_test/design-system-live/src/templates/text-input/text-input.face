{% comment %} Text Input — Form Field Component {% endcomment %}
{% include "_common-field" %}

{% assign field_id = field.id | default: "single-line" %}
{% assign field_name = field.name | default: "Single_Line" %}
{% assign field_label = field.label | default: "Single Line" %}
{% assign field_placeholder = field.placeholder | default: "" %}
{% assign field_maxlength = field.maxlength | default: "255" %}

<div class="form-group clearfix zc-{{ field_name }}-group{% if field.disabled %} zc-field-disabled{% endif %}" data-element-type="text-input" data-element-id="{{ field_id }}">

  <label class="form-label zc-dem-clearfix zc-{{ field_name }}-label zc_text_label" for="zc-{{ field_name }}" id="zc-{{ field_name }}-arialabel">
    <span class="zc-label-text">
      {{ field_label }}
      {% if field.required %}
        <span class="fieldMandate">*</span>
      {% endif %}
    </span>
  </label>

  <div class="form-field clearfix smallSizeLive{% if field.error %} select2Err validationError{% endif %}">
    <input
      class="form-control zc_textfield zc-{{ field_name }}"
      type="text"
      name="{{ field_name }}"
      id="zc-{{ field_name }}"
      maxlength="{{ field_maxlength }}"
      {% if field_placeholder != "" %}placeholder="{{ field_placeholder }}"{% endif %}
      {% if field.required %}
        required
        aria-required="true"
      {% endif %}
      {% if field.disabled %}
        disabled
        aria-disabled="true"
      {% endif %}
      autocomplete="off">

    {% if field.help_text %}
      <div class="zc-help-txt" id="zc-{{ field_name }}-helpText" style="white-space:pre-line;">{{ field.help_text }}</div>
    {% endif %}

    {% if field.error %}
      <div class="fieldErrorMsg zc-field-error-msg zc-dem-box-sizing" id="zc-{{ field_name }}-errorMsg" style="min-width:240px;width:240px">
        {% block error_icon %}{% endblock %}
        <span>{{ field.error_message | default: "This field is mandatory. Enter a value." }}</span>
      </div>
    {% endif %}
  </div>

</div>

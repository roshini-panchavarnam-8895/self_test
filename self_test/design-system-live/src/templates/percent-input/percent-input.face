{% comment %} Percent Input — Form Field Component {% endcomment %}
{% include "_common-field" %}

{% assign field_id = field.id | default: "percent" %}
{% assign field_name = field.name | default: "Percent" %}
{% assign field_label = field.label | default: "Percent" %}

<div class="form-group clearfix zc-{{ field_name }}-group" data-element-type="percent-input" data-element-id="{{ field_id }}">

  <label class="form-label zc-dem-clearfix zc-{{ field_name }}-label zc_percentage_label" for="zc-{{ field_name }}" id="zc-{{ field_name }}-arialabel">
    <span class="zc-label-text">
      {{ field_label }}
      {% if field.required %}
        <span class="fieldMandate">*</span>
      {% endif %}
    </span>
  </label>

  <div class="form-field clearfix zc-email-field smallSizeLive{% if field.error %} select2Err validationError{% endif %}">
    <input
      class="form-control zc_numberfield zc_percentage_field zc-{{ field_name }}"
      type="text"
      name="{{ field_name }}"
      id="zc-{{ field_name }}"
      maxlength="10"
      {% if field.required %}
        required
        aria-required="true"
      {% endif %}
      autocomplete="off">
    <i class="zc-prepend-icon zc-percent-icon">%</i>
  </div>

</div>

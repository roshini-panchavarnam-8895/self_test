                    <div class="detail-header">
                        <div class="detail-icon"><i class="fas fa-tasks"></i></div>
                        <div class="detail-info">
                            <h1 class="detail-title">Progress Bar</h1>
                            <p class="detail-description">Visual progress indicator using styled <code>&lt;div&gt;</code> elements. Variants: Default, Small, Tiny, With Label, Indeterminate across 4 color themes.</p>
                            <div class="detail-meta">
                                <span class="meta-tag"><i class="fas fa-folder"></i> Feedback</span>
                                <span class="meta-tag"><i class="fab fa-figma"></i> Figma Synced</span>
                                <span class="meta-tag"><i class="fas fa-layer-group"></i> 5 Types × 4 Colors</span>
                            </div>
                        </div>
                    </div>

                    <!-- Style Tabs -->
                    <div class="btn-style-tabs zc-mb-16 zc-mt-8">
                        <button class="btn-style-tab active" onclick="switchProgressbarStyleTab('default', this)">Default</button>
                        <button class="btn-style-tab" onclick="switchProgressbarStyleTab('sizes', this)">Sizes</button>
                        <button class="btn-style-tab" onclick="switchProgressbarStyleTab('colors', this)">Colors</button>
                        <button class="btn-style-tab" onclick="switchProgressbarStyleTab('with-label', this)">With Label</button>
                        <button class="btn-style-tab" onclick="switchProgressbarStyleTab('indeterminate', this)">Indeterminate</button>
                    </div>

                    <div id="progressbar-component-variants">

                        <!-- ==== DEFAULT ==== -->
                        <div class="btn-variant-group" data-style="default">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Default — Various Progress</span><button class="btn-variant-card__toggle" onclick="toggleProgressbarCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">25%</span>
                                        <div class="zc-progressbar">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 25%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">50%</span>
                                        <div class="zc-progressbar">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 50%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">75%</span>
                                        <div class="zc-progressbar">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 75%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">100%</span>
                                        <div class="zc-progressbar">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 100%"></div></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchProgressbarCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchProgressbarCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- 25% progress --&gt;
&lt;div class="zc-progressbar"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 25%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- 50% progress --&gt;
&lt;div class="zc-progressbar"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 50%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- 75% progress --&gt;
&lt;div class="zc-progressbar"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 75%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- 100% progress --&gt;
&lt;div class="zc-progressbar"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 100%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-progressbar-track {
  width: 100%;
  height: 8px;
  background: var(--zc-color-neutral-surface-neutral-surface-subtle, #F0F1F3);
  border-radius: 4px;
  overflow: hidden;
}
.zc-progressbar-fill {
  height: 100%;
  background: var(--zc-color-primary-surface-primary-surface-default, #0D4EF2);
  border-radius: 4px;
  transition: width 0.4s ease;
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== SIZES ==== -->
                        <div class="btn-variant-group" data-style="sizes" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Sizes — Default, Small, Tiny</span><button class="btn-variant-card__toggle" onclick="toggleProgressbarCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Default (8px)</span>
                                        <div class="zc-progressbar">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Small (4px)</span>
                                        <div class="zc-progressbar zc-progressbar-sm">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Tiny (2px)</span>
                                        <div class="zc-progressbar zc-progressbar-xs">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchProgressbarCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchProgressbarCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Default (8px height) --&gt;
&lt;div class="zc-progressbar"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Small (4px height) --&gt;
&lt;div class="zc-progressbar zc-progressbar-sm"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Tiny (2px height) --&gt;
&lt;div class="zc-progressbar zc-progressbar-xs"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>/* Default: 8px */
.zc-progressbar-track { height: 8px; }

/* Small: 4px */
.zc-progressbar-sm .zc-progressbar-track { height: 4px; }

/* Tiny: 2px */
.zc-progressbar-xs .zc-progressbar-track { height: 2px; }</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== COLORS ==== -->
                        <div class="btn-variant-group" data-style="colors" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Color Themes</span><button class="btn-variant-card__toggle" onclick="toggleProgressbarCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Primary</span>
                                        <div class="zc-progressbar">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Success</span>
                                        <div class="zc-progressbar zc-progressbar-success">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Warning</span>
                                        <div class="zc-progressbar zc-progressbar-warning">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Error</span>
                                        <div class="zc-progressbar zc-progressbar-error">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchProgressbarCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchProgressbarCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Primary (default) --&gt;
&lt;div class="zc-progressbar"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Success --&gt;
&lt;div class="zc-progressbar zc-progressbar-success"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Warning --&gt;
&lt;div class="zc-progressbar zc-progressbar-warning"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Error --&gt;
&lt;div class="zc-progressbar zc-progressbar-error"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>/* Primary (default) */
.zc-progressbar-fill {
  background: var(--zc-color-primary-surface-primary-surface-default, #0D4EF2);
}

/* Success */
.zc-progressbar-success .zc-progressbar-fill {
  background: var(--zc-color-success-surface-success-surface-default, #078841);
}

/* Warning */
.zc-progressbar-warning .zc-progressbar-fill {
  background: var(--zc-color-warning-surface-warning-surface-default, #D25704);
}

/* Error */
.zc-progressbar-error .zc-progressbar-fill {
  background: var(--zc-color-error-surface-error-surface-default, #CC1914);
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== WITH LABEL ==== -->
                        <div class="btn-variant-group" data-style="with-label" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">With Label &amp; Percentage</span><button class="btn-variant-card__toggle" onclick="toggleProgressbarCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Uploading</span>
                                        <div class="zc-progressbar zc-progressbar-labeled">
                                            <div class="zc-progressbar-header">
                                                <span class="zc-progressbar-label">Uploading...</span>
                                                <span class="zc-progressbar-percent">60%</span>
                                            </div>
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 60%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Processing</span>
                                        <div class="zc-progressbar zc-progressbar-labeled">
                                            <div class="zc-progressbar-header">
                                                <span class="zc-progressbar-label">Processing files...</span>
                                                <span class="zc-progressbar-percent">35%</span>
                                            </div>
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 35%"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Complete</span>
                                        <div class="zc-progressbar zc-progressbar-labeled zc-progressbar-success">
                                            <div class="zc-progressbar-header">
                                                <span class="zc-progressbar-label">Upload complete</span>
                                                <span class="zc-progressbar-percent">100%</span>
                                            </div>
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill" style="width: 100%"></div></div>
                                        </div>

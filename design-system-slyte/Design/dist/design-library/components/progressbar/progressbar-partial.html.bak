                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchProgressbarCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchProgressbarCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- With Label and Percentage --&gt;
&lt;div class="zc-progressbar zc-progressbar-labeled"&gt;
  &lt;div class="zc-progressbar-header"&gt;
    &lt;span class="zc-progressbar-label"&gt;Uploading...&lt;/span&gt;
    &lt;span class="zc-progressbar-percent"&gt;60%&lt;/span&gt;
  &lt;/div&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 60%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- With Label — Success Complete --&gt;
&lt;div class="zc-progressbar zc-progressbar-labeled zc-progressbar-success"&gt;
  &lt;div class="zc-progressbar-header"&gt;
    &lt;span class="zc-progressbar-label"&gt;Upload complete&lt;/span&gt;
    &lt;span class="zc-progressbar-percent"&gt;100%&lt;/span&gt;
  &lt;/div&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill" style="width: 100%"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-progressbar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.zc-progressbar-label {
  font-size: var(--zc-p2-font-size, 14px);
  font-weight: var(--zc-p2-font-weight-semibold, 600);
  color: var(--zc-color-neutral-text-neutral-text-default, #37383C);
}
.zc-progressbar-percent {
  font-size: var(--zc-p3-font-size, 12px);
  color: var(--zc-color-neutral-text-neutral-text-secondary, #696C74);
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                        <!-- ==== INDETERMINATE ==== -->
                        <div class="btn-variant-group" data-style="indeterminate" style="display:none">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Indeterminate — Animated</span><button class="btn-variant-card__toggle" onclick="toggleProgressbarCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>
                                <div class="btn-variant-card__preview">
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Default</span>
                                        <div class="zc-progressbar zc-progressbar-indeterminate">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Small</span>
                                        <div class="zc-progressbar zc-progressbar-sm zc-progressbar-indeterminate">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill"></div></div>
                                        </div>
                                    </div>
                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Tiny</span>
                                        <div class="zc-progressbar zc-progressbar-xs zc-progressbar-indeterminate">
                                            <div class="zc-progressbar-track"><div class="zc-progressbar-fill"></div></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchProgressbarCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchProgressbarCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Indeterminate (no percentage) --&gt;
&lt;div class="zc-progressbar zc-progressbar-indeterminate"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Indeterminate — Small --&gt;
&lt;div class="zc-progressbar zc-progressbar-sm zc-progressbar-indeterminate"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Indeterminate — Tiny --&gt;
&lt;div class="zc-progressbar zc-progressbar-xs zc-progressbar-indeterminate"&gt;
  &lt;div class="zc-progressbar-track"&gt;
    &lt;div class="zc-progressbar-fill"&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyProgressbarCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-progressbar-indeterminate .zc-progressbar-fill {
  width: 30% !important;
  animation: zc-progress-indeterminate 1.5s infinite ease-in-out;
}

@keyframes zc-progress-indeterminate {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(400%); }
}</code></pre></div>
                                </div>
                            </div>
                        </div>

                    </div>
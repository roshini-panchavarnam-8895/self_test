                                    <div class="btn-size-row">
                                        <span class="btn-size-label">Top</span>
                                        <div class="zc-popover-demo">
                                            <div class="zc-popover zc-popover-top zc-popover-align-center" style="position:relative; margin-bottom:12px;">
                                                <div class="zc-popover-arrow" style="bottom:-5px; left:50%; margin-left:-4px; border-top:none; border-left:none;"></div>
                                                <div class="zc-popover-content">
                                                    <div class="zc-popover-body">This is a simple popover with body text only.</div>
                                                </div>
                                            </div>
                                            <button class="zc-btn-demo">Trigger</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="btn-code-panel" style="display:none">
                                    <div class="btn-code-tabs"><button class="btn-code-tab active" onclick="switchPopoverCodeTab('html', this)">HTML</button><button class="btn-code-tab" onclick="switchPopoverCodeTab('scss', this)">SCSS</button></div>
                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyPopoverCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Basic Popover -- Bottom --&gt;
&lt;div class="zc-popover-demo"&gt;
    &lt;button class="zc-btn-demo"&gt;Trigger&lt;/button&gt;
    &lt;div class="zc-popover zc-popover-bottom zc-popover-align-center"&gt;
        &lt;div class="zc-popover-arrow"&gt;&lt;/div&gt;
        &lt;div class="zc-popover-content"&gt;
            &lt;div class="zc-popover-body"&gt;Popover body text.&lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyPopoverCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-popover {
    position: absolute;
    z-index: 1000;
    max-width: 280px;
    background: var(--zc-color-black-white-surface-white-surface, #FFFFFF);
    border: 1px solid var(--zc-color-neutral-border-neutral-border-default, #E4E5E8);
    border-radius: var(--zc-radius-rl, 8px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    font-family: 'ZohoPuvi', sans-serif;
}
.zc-popover-content { padding: 12px 16px; }
.zc-popover-body {
    font-size: var(--zc-p2-font-size, 14px);
    color: var(--zc-color-neutral-text-neutral-text-secondary, #696C74);
    line-height: 20px;
}</code></pre></div>

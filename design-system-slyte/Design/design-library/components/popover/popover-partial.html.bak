                        <!-- ==== BASIC ==== -->
                        <div class="btn-variant-group" data-style="basic">
                            <div class="btn-variant-card">
                                <div class="btn-variant-card__header"><span class="btn-variant-card__title">Basic Popover &mdash; Body Only</span><button class="btn-variant-card__toggle" onclick="togglePopoverCodePanel(this)"><i class="fas fa-code"></i><span>Show Code</span></button></div>

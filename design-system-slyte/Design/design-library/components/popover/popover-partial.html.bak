                                    <div class="btn-code-block" data-lang="html" style="display:block"><div class="btn-code-header"><span>HTML</span><button onclick="copyPopoverCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>&lt;!-- Popover with Actions -- Bottom --&gt;
&lt;div class="zc-popover-demo"&gt;
    &lt;button class="zc-btn-demo"&gt;Click me&lt;/button&gt;
    &lt;div class="zc-popover zc-popover-bottom zc-popover-align-center"&gt;
        &lt;div class="zc-popover-arrow"&gt;&lt;/div&gt;
        &lt;div class="zc-popover-content"&gt;
            &lt;div class="zc-popover-title"&gt;Confirm Action&lt;/div&gt;
            &lt;div class="zc-popover-body"&gt;Are you sure you want to proceed?&lt;/div&gt;
        &lt;/div&gt;
        &lt;div class="zc-popover-actions"&gt;
            &lt;button class="zc-popover-btn zc-popover-btn-secondary"&gt;Cancel&lt;/button&gt;
            &lt;button class="zc-popover-btn zc-popover-btn-primary"&gt;Confirm&lt;/button&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre></div>
                                    <div class="btn-code-block" data-lang="scss" style="display:none"><div class="btn-code-header"><span>SCSS</span><button onclick="copyPopoverCode(this)"><i class="fas fa-copy"></i></button></div><pre><code>.zc-popover-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding: 8px 16px 12px;
    border-top: 1px solid var(--zc-color-neutral-border-neutral-border-default, #E4E5E8);
}
.zc-popover-btn {
    padding: 6px 16px;
    border-radius: var(--zc-radius-rs, 6px);
    font-size: var(--zc-p2-font-size, 14px);
    font-weight: var(--zc-p2-font-weight-semibold, 600);
}
.zc-popover-btn-secondary {
    background: var(--zc-color-black-white-surface-white-surface, #FFFFFF);
    color: var(--zc-color-neutral-text-neutral-text-default, #37383C);
    border-color: var(--zc-color-neutral-border-neutral-border-default, #E4E5E8);
}
.zc-popover-btn-primary {
    background: var(--zc-color-primary-surface-primary-surface-default, #2D62ED);
    color: var(--zc-color-black-white-text-white-text, #FFFFFF);
}</code></pre></div>

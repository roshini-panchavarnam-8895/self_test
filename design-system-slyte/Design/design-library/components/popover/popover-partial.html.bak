                        <div class="detail-info">
                            <h1 class="detail-title">Popover</h1>
                            <p class="detail-description">Contextual overlay container using <code>&lt;lyte-popover&gt;</code> Slyte DOM. Displays supplementary content anchored to a trigger element with an arrow caret.</p>
                            <div class="detail-meta">
                                <span class="meta-tag"><i class="fas fa-folder"></i> Overlay</span>
                                <span class="meta-tag"><i class="fab fa-figma"></i> Figma Synced</span>
                                <span class="meta-tag"><i class="fas fa-layer-group"></i> 4 Positions &times; 3 Alignments</span>
                            </div>
                        </div>
